{{!< default}}

<section class="error-wrapper inner" style="display: flex; align-items: center; justify-content: center; min-height: 60vh;">
    <div class="error-container" style="text-align: center; padding: 4rem 1rem;">
        <h1 class="error-code" style="font-size: 10rem; font-weight: 800; color: var(--accent-color); margin-bottom: 0.5rem; line-height: 1;">404</h1>
        <p class="error-description" style="font-size: 1.5rem; color: var(--text-secondary); margin-bottom: 2.5rem; font-weight: 500;">Page not found</p>
        <a class="button button-primary error-link" href="{{@site.url}}">Go to the front page &rarr;</a>
    </div>
</section>
