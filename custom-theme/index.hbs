{{!< default}}
{{#contentFor "custom_body_class"}}is-main-feed{{/contentFor}}

<header class="site-hero inner">
    <div class="hero-card {{#if @site.cover_image}}has-image{{/if}}">
        <div class="hero-card-content">
            <h1 class="hero-title">Hello, welcome to {{@site.title}}.</h1>
            <p class="hero-description">{{@site.description}}</p>
            
            {{#if @site.members_enabled}}
            {{#unless @member}}
            <form class="hero-subscribe-form" data-members-form="subscribe">
                <input class="hero-subscribe-input" data-members-email type="email" placeholder="Your email" required="true" />
                <button class="button button-primary hero-subscribe-button" type="submit">Subscribe</button>
                <p class="hero-subscribe-success">Check your inbox and click the link to confirm your subscription.</p>
                <p class="hero-subscribe-error" data-members-error><!-- error message will appear here --></p>
            </form>
            {{/unless}}
            {{/if}}
        </div>
        
        {{#if @site.cover_image}}
        <div class="hero-card-image-wrapper">
            <img class="hero-card-image" 
                 srcset="{{img_url @site.cover_image size="s"}} 300w,
                         {{img_url @site.cover_image size="m"}} 600w,
                         {{img_url @site.cover_image size="l"}} 1000w,
                         {{img_url @site.cover_image size="xl"}} 2000w"
                 sizes="(max-width: 1000px) 100vw, 700px"
                 src="{{img_url @site.cover_image size="xl"}}" 
                 alt="{{@site.title}}" 
                 fetchpriority="high" />
        </div>
        {{/if}}
    </div>
</header>

<div class="post-feed inner">
    {{#foreach posts}}
        <article class="post-card {{post_class}} {{#has visibility="paid"}}is-paid{{/has}}">
            <a class="post-card-image-link" href="{{url}}">
                {{#if feature_image}}
                    <img class="post-card-image {{#has visibility="paid,members"}}blur-feature-image{{/has}}" 
                         srcset="{{img_url feature_image size="s"}} 300w,
                                 {{img_url feature_image size="m"}} 600w,
                                 {{img_url feature_image size="l"}} 1000w"
                         sizes="(max-width: 600px) 100vw, (max-width: 1000px) 33vw, 400px"
                         src="{{img_url feature_image size="m"}}" 
                         alt="{{title}}" 
                         loading="lazy" />
                {{else}}
                    <div class="post-card-no-image"></div>
                {{/if}}
            </a>
            <div class="post-card-content">
                <a class="post-card-content-link" href="{{url}}">
                    <header class="post-card-header">
                        {{#if primary_tag}}
                            <span class="post-card-primary-tag">{{primary_tag.name}}</span>
                        {{/if}}
                        {{#has visibility="members"}}<span class="post-card-visibility">Members only</span>{{/has}}
                        <h2 class="post-card-title">{{title}}</h2>
                    </header>
                    <div class="post-card-excerpt">
                        {{#if access}}
                            {{#if excerpt}}
                                <p>{{excerpt words="100"}}</p>
                            {{/if}}
                        {{else}}
                            <p class="excerpt-placeholder">This post is for family and friends only. Please join or sign in to continue reading.</p>
                        {{/if}}
                    </div>
                </a>
                <footer class="post-card-meta">
                    <span class="reading-time">{{reading_time}}</span>
                    <time class="post-date" datetime="{{date format='YYYY-MM-DD'}}">{{date format="MMMM D, YYYY"}}</time>
                </footer>
            </div>
        </article>
    {{/foreach}}
</div>

{{pagination}}
